{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "$uid === auth.uid || root.child('admins').child(auth.uid).exists() || auth.token.email === 'tjswp757@gmail.com' || auth.token.email === 'tjswo757@gmail.com'",
        "nick": { ".validate": "newData.isString() && newData.val().length >= 2 && newData.val().length <= 12" }
      }
    },
    "nicknames": {
      "$nick": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || data.val() === auth.uid)",
        ".validate": "newData.isString() && newData.val() === auth.uid"
      }
    },
    "admins": {
      ".read": "auth != null",
      "$uid": {
        ".write": "root.child('admins').child(auth.uid).exists() || auth.token.email === 'tjswp757@gmail.com' || auth.token.email === 'tjswo757@gmail.com'"
      }
    },
    "submissions": {
      ".read": "auth != null",
      "$mid": {
        "$uid": {
          ".write": "auth != null && ($uid === auth.uid || root.child('admins').child(auth.uid).exists() || auth.token.email === 'tjswp757@gmail.com' || auth.token.email === 'tjswo757@gmail.com')",
          "nick":  { ".validate": "newData.isString()" },
          "photo": { ".validate": "newData.isString() && newData.val().length < 400000" }
        }
      }
    },
    "leaderboard": {
      ".read": "auth != null",
      "$uid": { ".write": "$uid === auth.uid" }
    }
  }
}
